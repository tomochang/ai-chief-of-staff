#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

if [[ "${SKIP_TESTS_ON_PUSH:-0}" == "1" ]]; then
  echo "[pre-push] SKIP_TESTS_ON_PUSH=1 -> skipping npm test"
  exit 0
fi

echo "[pre-push] Running npm test..."
npm test
echo "[pre-push] Tests passed. Continuing push."
